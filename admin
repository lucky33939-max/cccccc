class Roadmap {
  constructor() {
    this.results = [];
  }

  add(result) {
    this.results.push(result);
  }

  beadRoad() {
    return this.results.map((r, i) => ({
      index: i,
      result: r
    }));
  }

  bigRoad() {
    const columns = [];
    let currentCol = [];

    for (const r of this.results) {
      if (currentCol.length === 0) {
        currentCol.push(r);
      } else {
        const last = currentCol[0];

        if (r === last) {
          currentCol.push(r);
        } else {
          columns.push(currentCol);
          currentCol = [r];
        }
      }
    }

    if (currentCol.length) columns.push(currentCol);

    return columns;
  }
}


